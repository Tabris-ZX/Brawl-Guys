<Window x:Class="BrawlGuys.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="FightingGuys"
        Width="1080"
        Height="800"
        MinWidth="1080"
        MinHeight="800"
        FontFamily="Microsoft YaHei UI"
        Icon="Resources/Images/Icons/app.ico">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles/ControlStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <SolidColorBrush x:Key="TextPrimaryBrush" Color="#202124" />
            <SolidColorBrush x:Key="TextMutedBrush" Color="#5F6368" />
            <SolidColorBrush x:Key="TextTitleBrush" Color="#202124" />
            <SolidColorBrush x:Key="TextSectionBrush" Color="#202124" />
            <SolidColorBrush x:Key="TextGoodBrush" Color="#1A73E8" />
            <SolidColorBrush x:Key="TextDangerBrush" Color="#D93025" />
            <SolidColorBrush x:Key="TextStatusBrush" Color="#B06000" />
            <Style TargetType="TextBlock">
                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
                <Setter Property="FontFamily" Value="Microsoft YaHei UI" />
            </Style>
            <Style TargetType="Button">
                <Setter Property="Foreground" Value="#FFFFFF" />
                <Setter Property="Background" Value="#1A73E8" />
                <Setter Property="BorderBrush" Value="#1A73E8" />
                <Setter Property="FontWeight" Value="SemiBold" />
            </Style>
        </ResourceDictionary>
    </Window.Resources>

    <Window.Background>
        <SolidColorBrush Color="#F8F9FA" />
    </Window.Background>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border x:Name="TopBarCard" Grid.Row="0"
                Margin="10,0,0,10"
                Padding="12"
                Background="#FFFFFF"
                BorderBrush="#E0E3E7"
                BorderThickness="1"
                CornerRadius="20">
            <Border.Effect>
                <DropShadowEffect BlurRadius="20" ShadowDepth="0" Opacity="0.10" Color="#DADCE0" />
            </Border.Effect>
            <DockPanel LastChildFill="False">
                <StackPanel DockPanel.Dock="Left">
                    <TextBlock FontSize="28"
                               FontWeight="Bold"
                               Foreground="{StaticResource TextTitleBrush}"
                               Text="Brawl Guys" />
                    <TextBlock Margin="0,4,0,0"
                               FontSize="13"
                               Foreground="{StaticResource TextMutedBrush}"
                               Text="v0.3.3-beta" />
                </StackPanel>

                <StackPanel DockPanel.Dock="Right"
                            Orientation="Horizontal"
                            VerticalAlignment="Bottom">
                    <StackPanel Margin="0,0,12,0">
                        <TextBlock Margin="0,0,0,6" Foreground="{StaticResource TextMutedBrush}" Text="倍速" />
                        <ComboBox x:Name="SpeedCombo"
                                  Width="88"
                                  Style="{StaticResource ModernComboBoxStyle}"
                                  SelectionChanged="SpeedCombo_SelectionChanged">
                            <ComboBoxItem Content="0.5x" Tag="0.5" />
                            <ComboBoxItem Content="1.0x" Tag="1.0" />
                            <ComboBoxItem Content="2.0x" Tag="2.0" />
                            <ComboBoxItem Content="4.0x" Tag="4.0" />
                        </ComboBox>
                    </StackPanel>

                    <StackPanel Margin="0,0,12,0">
                        <TextBlock Margin="0,0,0,6" Foreground="{StaticResource TextMutedBrush}" Text="缩放" />
                        <ComboBox x:Name="ScaleCombo"
                                  Width="88"
                                  Style="{StaticResource ModernComboBoxStyle}"
                                  SelectionChanged="ScaleCombo_SelectionChanged">
                            <ComboBoxItem Content="75%" Tag="0.75" />
                            <ComboBoxItem Content="100%" Tag="1.00" />
                            <ComboBoxItem Content="125%" Tag="1.25" />
                            <ComboBoxItem Content="150%" Tag="1.50" />
                        </ComboBox>
                    </StackPanel>
                    
                    <Button x:Name="ModeToggleButton"
                            Width="86"
                            Height="34"
                            Margin="0,20,10,0"
                            Click="ModeToggleButton_OnClick"
                            Background="#FFFFFF"
                            Foreground="#202124"
                            BorderBrush="#DADCE0"
                            Content="切换2v2" />

                    <Button x:Name="ThemeToggleButton"
                            Width="72"
                            Height="34"
                            Margin="0,20,10,0"
                            Click="ThemeToggleButton_OnClick"
                            Background="#FFFFFF"
                            Foreground="#202124"
                            BorderBrush="#DADCE0"
                            Content="暗色" />
                    
                    <Button x:Name="PauseButton"
                            Width="80"
                            Height="34"
                            Margin="0,20,10,0"
                            Click="PauseButton_OnClick"
                            Background="#1A73E8"
                            Foreground="#FFFFFF"
                            BorderBrush="#1A73E8"
                            Content="暂停" />

                    <Button x:Name="RestartButton"
                            Width="80"
                            Height="34"
                            Margin="0,20,0,0"
                            Click="RestartButton_OnClick"
                            Background="#FFFFFF"
                            Foreground="#202124"
                            BorderBrush="#DADCE0"
                            Content="重开" />
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Grid.Row="1" VerticalAlignment="Top">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="360" />
            </Grid.ColumnDefinitions>

            <Border x:Name="ArenaOuterBorder" Grid.Column="0"
                    Margin="0,0,12,0"
                    Padding="0"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    Background="#4285F4"
                    BorderBrush="#AECBFA"
                    BorderThickness="1"
                    CornerRadius="18">
                <Border x:Name="ArenaInnerBorder" BorderBrush="#D2E3FC"
                        BorderThickness="3"
                        CornerRadius="0"
                        Background="#1967D2"
                        ClipToBounds="True">
                    <Canvas x:Name="ArenaCanvas"
                            Width="600"
                            Height="600"
                            ClipToBounds="True"
                            SnapsToDevicePixels="True" />
                </Border>
            </Border>

            <ScrollViewer Grid.Column="1"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel>


                <Border x:Name="InfoPanelCard"
                        Margin="0,0,0,10"
                        Padding="12"
                        Background="#FFFFFF"
                        BorderBrush="#E0E3E7"
                        BorderThickness="1"
                        CornerRadius="20">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="20" ShadowDepth="0" Opacity="0.08" Color="#DADCE0" />
                    </Border.Effect>
                    <StackPanel>
                        <TextBlock FontSize="18"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource TextSectionBrush}"
                                   Text="对战信息" />

                        <Border x:Name="StatusBanner"
                                Margin="0,8,0,10"
                                Padding="10,8"
                                Background="#FEF7E0"
                                BorderBrush="#FDD663"
                                BorderThickness="1"
                                CornerRadius="10">
                            <TextBlock x:Name="StatusTextBlock"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource TextStatusBrush}"
                                       Text="准备开始" />
                        </Border>

                        <Border x:Name="LeftInfoCard"
                                Margin="0,0,0,8"
                                Padding="10"
                                Background="#F8F9FA"
                                BorderBrush="#E8EAED"
                                BorderThickness="1"
                                CornerRadius="12">
                            <StackPanel>
                                <TextBlock Margin="0,0,0,6"
                                           FontSize="12"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           Text="蓝方" />
                                <Grid x:Name="LeftFighterComboGrid" Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <ComboBox x:Name="LeftFighterCombo"
                                              Grid.Column="0"
                                              Style="{StaticResource ModernComboBoxStyle}"
                                              SelectionChanged="FighterSelectionChanged" />
                                    <ComboBox x:Name="LeftFighterCombo2"
                                              Grid.Column="1"
                                              Margin="8,0,0,0"
                                              Style="{StaticResource ModernComboBoxStyle}"
                                              Visibility="Collapsed"
                                              SelectionChanged="FighterSelectionChanged" />
                                </Grid>
                                <TextBlock x:Name="LeftNameTextBlock"
                                           FontSize="14"
                                           FontWeight="Bold"
                                           TextWrapping="NoWrap"
                                           TextTrimming="CharacterEllipsis"
                                           Foreground="{StaticResource TextGoodBrush}" />
                                <ProgressBar x:Name="LeftHealthBar"
                                             Height="12"
                                             Margin="0,6,0,4"
                                             Maximum="100"
                                             Foreground="#4285F4"
                                             Value="100" />
                                <TextBlock x:Name="LeftHealthTextBlock"
                                           Foreground="{StaticResource TextGoodBrush}"
                                           Text="HP" />
                                <TextBlock x:Name="LeftdescTextBlock"
                                           Margin="0,6,0,0"
                                           FontSize="12"
                                           TextWrapping="Wrap"
                                           Foreground="#5F6368"
                                           Text="描述" />
                            </StackPanel>
                        </Border>

                        <Border x:Name="RightInfoCard"
                                Padding="10"
                                Background="#F8F9FA"
                                BorderBrush="#E8EAED"
                                BorderThickness="1"
                                CornerRadius="12">
                            <StackPanel>
                                <TextBlock Margin="0,0,0,6"
                                           FontSize="12"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           Text="红方" />
                                <Grid x:Name="RightFighterComboGrid" Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <ComboBox x:Name="RightFighterCombo"
                                              Grid.Column="0"
                                              Style="{StaticResource ModernComboBoxStyle}"
                                              SelectionChanged="FighterSelectionChanged" />
                                    <ComboBox x:Name="RightFighterCombo2"
                                              Grid.Column="1"
                                              Margin="8,0,0,0"
                                              Style="{StaticResource ModernComboBoxStyle}"
                                              Visibility="Collapsed"
                                              SelectionChanged="FighterSelectionChanged" />
                                </Grid>
                                <TextBlock x:Name="RightNameTextBlock"
                                           FontSize="14"
                                           FontWeight="Bold"
                                           TextWrapping="NoWrap"
                                           TextTrimming="CharacterEllipsis"
                                           Foreground="{StaticResource TextDangerBrush}" />
                                <ProgressBar x:Name="RightHealthBar"
                                             Height="12"
                                             Margin="0,6,0,4"
                                             Maximum="100"
                                             Foreground="#EA4335"
                                             Value="100" />
                                <TextBlock x:Name="RightHealthTextBlock"
                                           Foreground="{StaticResource TextDangerBrush}"
                                           Text="HP" />
                                <TextBlock x:Name="RightdescTextBlock"
                                           Margin="0,6,0,0"
                                           FontSize="12"
                                           TextWrapping="Wrap"
                                           Foreground="#5F6368"
                                           Text="描述" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Border>

                <Border x:Name="BottomPlaceholderCard"
                        Padding="12"
                        Background="#FFFFFF"
                        BorderBrush="#E0E3E7"
                        BorderThickness="1"
                        CornerRadius="20">
                    <StackPanel>
                        <TextBlock FontSize="15"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource TextSectionBrush}"
                                   Text="平衡性测试" />
                        <TextBlock Margin="0,4,0,8"
                                   FontSize="12"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   Text="选择角色后，将与所有其他角色进行 64x 快速战斗模拟" />
                        <DockPanel Margin="0,0,0,10" LastChildFill="True">
                            <TextBlock DockPanel.Dock="Left"
                                       Width="86"
                                       VerticalAlignment="Center"
                                       FontSize="12"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       Text="每个对手" />
                            <TextBox x:Name="BalanceMatchCountTextBox"
                                     Height="32"
                                     Padding="8,5"
                                     Text="1000"
                                     ToolTip="每个对手的总对战场数，会自动拆分为原始站位和左右互换两部分" />
                        </DockPanel>
                        <Button x:Name="BalanceTestButton"
                                Height="38"
                                Click="BalanceTestButton_OnClick"
                                Background="#FFFFFF"
                                Foreground="#202124"
                                BorderBrush="#DADCE0"
                                Content="开始全角色平衡性测试" />
                    </StackPanel>
                </Border>
            </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</Window>
